{
  "name": "@unruly-software/faux",
  "packageManager": "yarn@3.5.0",
  "version": "1.1.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "yarn tsc --noEmit && microbundle",
    "build:watch": "yarn tsc --noEmit --watch",
    "clean": "rm -rf ./dist",
    "test": "vitest",
    "version": "changeset version",
    "release": "CI=true yarn --mode=update-lockfile && yarn build && CI=true yarn test && changeset publish",
    "lint": "eslint src/**/*.ts",
    "ci": "CI=true yarn build && CI=true yarn test --run --coverage && yarn lint"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.2",
    "@faker-js/faker": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "5.59.8",
    "@typescript-eslint/parser": "5.59.8",
    "@vitest/coverage-istanbul": "^0.32.2",
    "eslint": "8.41.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "microbundle": "^0.15.1",
    "prettier": "2.8.8",
    "typescript": "5.0.4",
    "uuid": "^13.0.0",
    "vitest": "^0.31.3",
    "zod": "^4.1.3"
  },
  "amdName": "faux",
  "main": "dist/faux.js",
  "module": "dist/faux.module.js",
  "types": "dist/index.d.ts",
  "umd:main": "dist/faux.umd.js",
  "source": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "umd": "./dist/faux.umd.js",
      "import": "./dist/faux.mjs",
      "require": "./dist/faux.js"
    }
  }
}
